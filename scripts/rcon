#!/bin/bash
# scripts/rcon - Send RCON commands to the ASA server

if [ $# -ne 1 ]; then
    echo "Usage: $0 '<command>'"
    exit 1
fi

# Load environment variables (for ADMIN_PASSWORD and RCON_PORT)
source "$(dirname "$0")/../.env"

# Use ADMIN_PASSWORD for RCON authentication
docker exec asa-server mcrcon -H localhost -P "$RCON_PORT" -p "$ADMIN_PASSWORD" "$1"
